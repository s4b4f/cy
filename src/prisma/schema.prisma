generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SongType {
  TEAM
  PLAYER
  CUSTOM
}

model Song {
  id             String   @id @default(cuid())
  name           String
  teamName       String
  playerName     String?
  type           SongType
  customTypeName String?
  assetId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type, createdAt])
  @@index([name])
  @@index([teamName])
  @@index([playerName])
  @@index([customTypeName])
  @@index([createdAt])
}
